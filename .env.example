# ─────────────────────────────────────────────────────────────
# AI 유튜브 자동 발행 워크플로우 - 환경변수 예시
# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (cp .env.example .env)
# GitHub Actions 로 자동화할 때는 저장소 Secrets 에 동일한 키로 등록하세요.
# ─────────────────────────────────────────────────────────────

# ── Anthropic (Claude) : 대본/구성 생성 ──
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# 사용할 모델 (기본: claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# ── ElevenLabs : 나레이션(TTS) ──
# https://elevenlabs.io/app/settings/api-keys 에서 발급
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# 한국어에 잘 맞는 목소리 ID (Voice Library 에서 복사). 기본값은 다국어 예시 voice.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# TTS 모델 (한국어는 다국어 모델 권장)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── YouTube Data API v3 (GCP) : 업로드 ──
# GCP 콘솔에서 OAuth 클라이언트(데스크톱 앱) 생성 후 값 입력
# 자세한 절차는 README 참고. refresh token 은 `npm run authorize:youtube` 로 발급.
YOUTUBE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx
# 업로드 공개 상태: public | unlisted | private
YOUTUBE_PRIVACY_STATUS=private
# 업로드 후 category (기본 27 = Education)
YOUTUBE_CATEGORY_ID=27

# ── 콘텐츠 설정 ──
# 영상 주제 모드: trend(최신 AI 트렌드) | basics(AI 기초 상식) | auto(요일별 자동)
CONTENT_MODE=auto
# 대상 영상 길이(분). 대본 분량 가이드로 사용됩니다.
TARGET_MINUTES=10
# 영상/자막 언어
CONTENT_LANGUAGE=ko

# ── 파이프라인 동작 ──
# true 이면 실제 업로드까지 진행, false 이면 렌더까지만 (out/ 에 mp4 저장)
DO_UPLOAD=false
